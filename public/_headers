# Security headers for all routes
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Aggressive cache for hashed JS/CSS bundles (Vite adds content hashes)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache images for 1 day, revalidate in background after that
# This ensures new/updated images appear within 24h max
/asset/member_active/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400
/asset/exmember/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400
/asset/Setlist/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/asset/SSRamadan/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/asset/SPV_MV/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/asset/icon/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=86400

# No cache for HTML — always serve fresh on deploy
/
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
